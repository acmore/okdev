apiVersion: okdev.io/v1alpha1
kind: DevEnvironment
metadata:
  name: {{ .Name }}
spec:
  namespace: {{ .Namespace }}
  session:
    defaultNameTemplate: '{{`{{ .Repo }}-{{ .Branch }}-{{ .User }}`}}'
    ttlHours: {{ .TTLHours }}
    idleTimeoutMinutes: 120
    shareable: true
  sync:
    engine: syncthing
    syncthing:
      version: {{ .SyncthingVersion }}
      autoInstall: true
    paths:
      - "{{ .SyncLocal }}:{{ .SyncRemote }}"
    remoteExclude: []
  ports:
    - name: api
      local: 8080
      remote: 8080
    - name: tensorboard
      local: 6006
      remote: 6006
  ssh:
    user: {{ .SSHUser }}
    keepAliveIntervalSeconds: 30
    keepAliveTimeoutSeconds: 90
  sidecar:
    image: {{ .SidecarImage }}
  podTemplate:
    spec:
      containers:
        - name: dev
          image: {{ .BaseImage }}
          command: ["sleep", "infinity"]
          resources:
            requests:
              cpu: "8"
              memory: 32Gi
              nvidia.com/gpu: "{{ .GPUCount }}"
            limits:
              cpu: "16"
              memory: 64Gi
              nvidia.com/gpu: "{{ .GPUCount }}"
          volumeMounts:
            - name: workspace
              mountPath: /workspace
      volumes:
        - name: workspace
          persistentVolumeClaim:
            claimName: okdev-workspace
