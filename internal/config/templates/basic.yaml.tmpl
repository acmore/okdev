apiVersion: okdev.io/v1alpha1
kind: DevEnvironment
metadata:
  name: {{ .Name }}
spec:
  namespace: {{ .Namespace }}
  session:
    defaultNameTemplate: '{{`{{ .Repo }}-{{ .User }}`}}'
    ttlHours: {{ .TTLHours }}
    idleTimeoutMinutes: 120
  sync:
    engine: syncthing
    syncthing:
      version: {{ .SyncthingVersion }}
      autoInstall: true
    paths:
      - "{{ .SyncLocal }}:{{ .SyncRemote }}"
  ports:
    - name: app
      local: 8080
      remote: 8080
{{- if ne .WorkloadType "pod" }}
  workload:
    type: {{ .WorkloadType }}
    manifestPath: {{ .ManifestPath }}
    inject:
{{- range .InjectPaths }}
      - path: "{{ . }}"
{{- end }}
{{- if .AttachContainer }}
    attach:
      container: {{ .AttachContainer }}
{{- end }}
{{- end }}
  ssh:
    user: {{ .SSHUser }}
    keepAliveIntervalSeconds: 30
    keepAliveTimeoutSeconds: 90
  sidecar:
{{- if .SidecarImage }}
    image: {{ .SidecarImage }}
{{- end }}
{{- if and (eq .WorkloadType "pod") .DevImage }}
  podTemplate:
    spec:
      containers:
        - name: dev
          image: {{ .DevImage }}
          command: ["sleep", "infinity"]
{{- end }}
